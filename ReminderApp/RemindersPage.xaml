<Page x:Class="ReminderApp.RemindersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReminderApp"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RemindersPage" Background="#F3F3F3">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Заголовок и кнопка добавления -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Напоминания" FontSize="28" FontWeight="Light"/>
            <Button Grid.Column="2" Name="AddRemindButton" Content="Добавить напоминание" Background="#2564CF" Foreground="White" Padding="15,8" 
            BorderThickness="0" Click="AddRemindButton_Click"/>
        </Grid>
        
        <!-- Список задач с напоминаниями -->
        <ListBox x:Name="RemindersListBox" Grid.Row="1" Background="Transparent" BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                        <CheckBox/>
                        <TextBlock Text="{Binding Title}" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ReminderTime}" Foreground="#777" Margin="20,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.Items>
                <StackPanel>
                    <CheckBox/>
                    <TextBlock Text="Позвонить врачу" FontSize="16"/>
                    <TextBlock Text="Сегодня, 16:00" Foreground="#777" Margin="20,0,0,0"/>
                </StackPanel>
                <StackPanel>
                    <CheckBox/>
                    <TextBlock Text="Забрать заказ" FontSize="16"/>
                    <TextBlock Text="Завтра, 11:00" Foreground="#777" Margin="20,0,0,0"/>
                </StackPanel>
            </ListBox.Items>
        </ListBox>
    </Grid>
</Page>

<Page x:Class="ReminderApp.TodayPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReminderApp"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="TodayPage" Background="#F3F3F3">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и кнопка добавления -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Сегодня" FontSize="28" FontWeight="Light"/>
            <TextBlock Grid.Column="1" Text="10 апреля" FontSize="16" Foreground="#777" VerticalAlignment="Bottom" Margin="10,0,0,5"/>
            <Button Grid.Column="2" Content="Добавить задачу" Background="#2564CF" Foreground="White" Padding="15,8" 
                    BorderThickness="0" Click="AddTaskButton_Click"/>
        </Grid>

        <!-- Список задач на сегодня -->
        <ListBox x:Name="TasksListBox" Grid.Row="1" Background="Transparent" BorderThickness="0"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                        <CheckBox/>
                        <TextBlock Text="{Binding Title}" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Time}" Foreground="#777" Margin="20,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <!-- Временные данные для примера -->
            <ListBox.Items>
                <StackPanel>
                    <CheckBox/>
                    <TextBlock Text="Купить продукты" FontSize="16"/>
                    <TextBlock Text="15:00" Foreground="#777" Margin="20,0,0,0"/>
                </StackPanel>
                <StackPanel>
                    <CheckBox/>
                    <TextBlock Text="Позвонить маме" FontSize="16"/>
                    <TextBlock Text="18:30" Foreground="#777" Margin="20,0,0,0"/>
                </StackPanel>
            </ListBox.Items>
        </ListBox>
    </Grid>
</Page>
